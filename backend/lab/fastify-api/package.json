{
  "name": "fastify-api-lab",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "build": "tsc",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "dev": "bun --watch src/server.ts",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "start": "bun src/server.ts",
    "test": "bun test test",
    "typecheck": "tsc --project tsconfig.test.json"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@fastify/type-provider-typebox": "^5.0.0",
    "@sinclair/typebox": "^0.34.0",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.3.0",
    "@types/node": "^24.0.0",
    "typescript": "^5.0.0"
  }
}
